    "import time\n",
    "import sys\n",
    "\n",
    "def type_effect(text, speed=0.05):\n",
    "    for char in text:\n",
    "        print(char, end='', flush=True)\n",
    "        time.sleep(speed)\n",
    "    print()  # saut de ligne à la fin\n",
    "\n",
    "def play_lyrics():\n",
    "    lyrics = [\n",
    "        (\"you gotta say that sorry\", 0.3),\n",
    "        (\"at the end of the night\", 0.4),\n",
    "        (\"wake up in the morning\", 0.4),\n",
    "        (\"everything is alright\", 0.4),\n",
    "        (\"at the end of the story\", 0.5),\n",
    "        (\"you are holding me tight\", 0.5),\n",
    "        (\"i don't need to worry\", 0.3),\n",
    "        (\"am i out of my mind\", 0.7)\n",
    "    ]\n",
    "\n",
    "    type_effect('♪ playing lyrics: love me not ♪', speed=0.07)\n",
    "    time.sleep(1)\n",
    "\n",
    "    for line, delay in lyrics:\n",
    "        type_effect(line, speed=0.07)  # effet d'écriture\n",
    "        time.sleep(delay)              # pause entre les lignes\n",
    "\n",
    "play_lyrics()"
   ],
